{
  "name": "pi-chrome-assistent",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "pi-package",
    "pi-extension",
    "chrome-extension"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./src/pi/browserConnectExtension.ts"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:chrome",
    "build:chrome": "node scripts/build-chrome.mjs"
  },
  "dependencies": {
    "ws": "8.21.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@types/chrome": "0.1.42",
    "@types/node": "24.12.4",
    "@types/ws": "8.18.1",
    "jsdom": "29.1.1",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "packageManager": "npm@11.6.2"
}
